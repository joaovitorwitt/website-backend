# Supabase: Project Settings -> Database -> Connection string -> URI
# Prefer the "Session pooler" / "Transaction pooler" URI over the direct one.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Set this when DATABASE_URL points at Supabase's transaction pooler (port 6543),
# which cannot hold session-level prepared statements.
# USE_TRANSACTION_POOLER=1

# Pool size is per gunicorn worker, so the real ceiling is POOL_MAX_SIZE * workers.
# POOL_MIN_SIZE=1
# POOL_MAX_SIZE=3

# Only used when DATABASE_URL is unset (e.g. a local postgres)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=postgres
# POSTGRES_SSLMODE=prefer

PORT=8000
